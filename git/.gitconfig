# This is Git's per-user configuration file.
[user]
	name = Ilya Sherman
	email = ishermandom@gmail.com
[init]
  defaultBranch = main
[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = true
  pager = true
[safe]
	directory = /Users/Shared/code/*
[alias]
	# Lands the current branch onto main with linear history; the script
	# documents the full workflow.
	land = !~/.claude/scripts/git-land.sh

# Account-specific configuration is layered in per account via stow overlays
# under accounts/<account>/ in the dotfiles repo. Credential handling lives
# there: https token storage is used only on the sandbox account, so it must
# not be baked into this shared file. A missing file is silently ignored, so
# accounts without an overlay (which use Git's defaults) need no entry.
[include]
	path = ~/.gitconfig.local
