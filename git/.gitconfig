# This is Git's per-user configuration file.
[user]
	name = Ilya Sherman
	email = ishermandom@gmail.com
[init]
  defaultBranch = main
[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = true
  pager = true
[safe]
	directory = /Users/Shared/code/*

# Override Xcode's system-level gitconfig (/Applications/Xcode.app/.../gitconfig),
# which sets osxkeychain as the default credential helper for all users.
# The empty string resets the helper chain before applying our own.
[credential]
	useHttpPath = true
	helper = 
	helper = store
